## Error 404 personalizado
ErrorDocument 404 /security/404.html

Options -Indexes
DirectoryIndex view/index.php

# Bloquear acceso web a archivos sensibles
<FilesMatch "^(env\.php|\.env|composer\.(json|lock)|\.gitignore)$">
	Require all denied
</FilesMatch>

RewriteEngine On
RewriteBase /ProyecteServidor1/

# Bloquear acceso web a logs
RewriteRule ^logs/ - [F,L,NC]
RewriteRule ^.*\.log$ - [F,L,NC]

# Entrada principal MVC sin index.php en raíz
RewriteRule ^$ controller/home.controller.php [L,QSA]
RewriteRule ^index\.php$ controller/home.controller.php [L,QSA]
RewriteRule ^view/index\.php$ controller/home.controller.php [L,QSA]
RewriteRule ^view/modificar\.vista\.php$ controller/modificarPage.controller.php [L,QSA]
RewriteRule ^view/perfilUsuario\.vista\.php$ controller/perfilUsuarioPage.controller.php [L,QSA]
RewriteRule ^view/resetearContrasena\.vista\.php$ controller/resetearContrasenaPage.controller.php [L,QSA]
RewriteRule ^view/insertar\.vista\.php$ controller/insertarPage.controller.php [L,QSA]

# Si no existe archivo/directorio real, redirigir al home controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . controller/home.controller.php [L,QSA]